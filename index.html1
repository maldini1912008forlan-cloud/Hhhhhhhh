<!DOCTYPE html>
<html>
<head>
<title>Welcome</title>

<style>
body{
margin:0;
overflow:hidden;
font-family:Arial;
background:black;
color:white;
}

/* البابين */
.door{
position:fixed;
top:0;
width:50%;
height:100%;
background:#111;
transition:2s;
z-index:2;
}

.left{
left:0;
border-right:3px solid #333;
}

.right{
right:0;
border-left:3px solid #333;
}

/* الرسالة */
.message{
position:absolute;
top:50%;
left:50%;
transform:translate(-50%,-50%);
font-size:40px;
opacity:0;
transition:2s;
text-align:center;
}
</style>
</head>

<body>

<div class="door left" id="leftDoor"></div>
<div class="door right" id="rightDoor"></div>

<div class="message" id="msg">
🎓 تالته ثانوي ترحب بك يا ملك 🎓
</div>

<script>

/* بعد ما الصفحة تفتح */
setTimeout(()=>{
document.getElementById("leftDoor").style.left="-50%";
document.getElementById("rightDoor").style.right="-50%";

setTimeout(()=>{
document.getElementById("msg").style.opacity="1";
},1500);

},1500);

</script>

</body>
</html>
